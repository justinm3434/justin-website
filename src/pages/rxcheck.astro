---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';

const metadata = {
  title: 'RxCheck — Drug Price Lookup',
  description: 'Look up prescription drug prices. Compare costs from Cost Plus Drugs, GoodRx, and more.',
};
---

<Layout metadata={metadata}>
  <Fragment slot="header">
    <Header
      links={[
        { text: 'Home', href: '/' },
        { text: 'Photos', href: '/#photos' },
        { text: 'Writing', href: '/#writing' },
        { text: 'Projects', href: '/#projects' },
        { text: 'Work', href: '/#work' },
      ]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <!-- ============================================ -->
  <!-- HERO                                          -->
  <!-- ============================================ -->
  <section class="pt-24 pb-12 sm:pt-32 sm:pb-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-xs uppercase tracking-[0.3em] text-muted mb-3">Tool</p>
      <h1 class="text-5xl sm:text-6xl font-heading font-bold italic mb-4">RxCheck</h1>
      <p class="text-base text-muted max-w-md mx-auto font-light leading-relaxed">
        Look up any prescription drug and see what it actually costs. Prices from Cost Plus Drugs, with links to GoodRx and TrumpRx.
      </p>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SEARCH                                        -->
  <!-- ============================================ -->
  <section class="pb-8">
    <div class="max-w-xl mx-auto px-4 sm:px-6">
      <div id="rx-search-container" class="relative">
        <div class="relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-white/30 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
          <input
            id="rx-search"
            type="text"
            placeholder="Search a drug — e.g. metformin, advil, insulin..."
            autocomplete="off"
            class="w-full pl-12 pr-4 py-4 rounded-xl bg-white/5 border border-white/10 text-white placeholder:text-white/30 text-base focus:outline-none focus:border-amber-400/50 focus:ring-2 focus:ring-amber-400/20 transition-all"
          />
        </div>

        <!-- Suggestions dropdown -->
        <div id="rx-suggestions" class="absolute z-50 left-0 right-0 mt-2 rounded-xl bg-gray-900 border border-white/10 shadow-2xl overflow-hidden hidden">
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- LOADING                                       -->
  <!-- ============================================ -->
  <div id="rx-loading" class="hidden py-16 text-center">
    <div class="inline-flex items-center gap-3 text-white/40 text-sm">
      <svg class="animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      Looking up prices...
    </div>
  </div>

  <!-- ============================================ -->
  <!-- RESULTS                                       -->
  <!-- ============================================ -->
  <section id="rx-results" class="hidden pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div id="rx-results-header" class="mb-8"></div>
      <div id="rx-results-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5"></div>
      <div id="rx-results-links" class="mt-8 text-center"></div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- NO RESULTS                                    -->
  <!-- ============================================ -->
  <div id="rx-no-results" class="hidden pb-20">
    <div class="max-w-lg mx-auto px-4 sm:px-6 text-center">
      <div class="rounded-2xl bg-white/[0.02] border border-white/5 p-8">
        <p class="text-white/50 text-sm mb-4" id="rx-no-results-text"></p>
        <div class="flex flex-wrap justify-center gap-3">
          <a id="rx-goodrx-link" href="#" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-xs font-medium text-white/60 hover:text-white hover:border-white/20 transition-all">
            Search on GoodRx &rarr;
          </a>
          <a href="https://www.trumprx.gov" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-xs font-medium text-white/60 hover:text-white hover:border-white/20 transition-all">
            Check TrumpRx.gov &rarr;
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- ERROR                                         -->
  <!-- ============================================ -->
  <div id="rx-error" class="hidden pb-20">
    <div class="max-w-lg mx-auto px-4 sm:px-6 text-center">
      <div class="rounded-2xl bg-red-400/5 border border-red-400/10 p-8">
        <p class="text-red-400/70 text-sm">Something went wrong. Please try again.</p>
      </div>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- DISCLAIMER                                    -->
  <!-- ============================================ -->
  <section class="pb-20">
    <div class="max-w-lg mx-auto px-4 sm:px-6 text-center">
      <p class="text-[11px] text-white/20 leading-relaxed">
        Prices shown are from Cost Plus Drugs and may not reflect final costs including shipping or insurance adjustments.
        This tool is for informational purposes only and is not medical advice. Always consult your healthcare provider.
      </p>
    </div>
  </section>

  <script is:inline>
    // =============================================
    // RxCheck — Drug Price Lookup
    // =============================================

    const RXNORM = 'https://rxnav.nlm.nih.gov/REST';
    const COSTPLUS = 'https://us-central1-costplusdrugs-publicapi.cloudfunctions.net/main';

    function init() {
      const searchInput = document.getElementById('rx-search');
      const suggestionsEl = document.getElementById('rx-suggestions');
      const resultsEl = document.getElementById('rx-results');
      const resultsHeader = document.getElementById('rx-results-header');
      const resultsGrid = document.getElementById('rx-results-grid');
      const resultsLinks = document.getElementById('rx-results-links');
      const loadingEl = document.getElementById('rx-loading');
      const errorEl = document.getElementById('rx-error');
      const noResultsEl = document.getElementById('rx-no-results');
      const noResultsText = document.getElementById('rx-no-results-text');
      const goodrxLink = document.getElementById('rx-goodrx-link');

      if (!searchInput) return;

      let activeIdx = -1;
      let suggestions = [];

      // -- Utilities --
      function debounce(fn, ms) {
        let t;
        return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), ms); };
      }

      async function fetchJSON(url) {
        const ctrl = new AbortController();
        const timer = setTimeout(() => ctrl.abort(), 10000);
        try {
          const r = await fetch(url, { signal: ctrl.signal });
          clearTimeout(timer);
          if (!r.ok) return null;
          return await r.json();
        } catch { clearTimeout(timer); return null; }
      }

      function formatPrice(p) {
        if (!p) return '—';
        const num = parseFloat(String(p).replace('$', ''));
        if (isNaN(num)) return '—';
        return '$' + num.toFixed(2);
      }

      // -- UI Helpers --
      function hideAll() {
        resultsEl.classList.add('hidden');
        loadingEl.classList.add('hidden');
        errorEl.classList.add('hidden');
        noResultsEl.classList.add('hidden');
      }

      function showLoading() { hideAll(); loadingEl.classList.remove('hidden'); }
      function showError() { hideAll(); errorEl.classList.remove('hidden'); }
      function showNoResults(name) {
        hideAll();
        noResultsText.textContent = '"' + name + '" isn\'t available on Cost Plus Drugs right now. It may be a brand-name drug or not yet in their catalog. Try these instead:';
        goodrxLink.href = 'https://www.goodrx.com/search?search=' + encodeURIComponent(name);
        noResultsEl.classList.remove('hidden');
      }

      function showSuggestions(items) {
        suggestions = items;
        activeIdx = -1;
        if (items.length === 0) { hideSuggestions(); return; }
        suggestionsEl.innerHTML = items.map((item, i) =>
          '<button data-idx="' + i + '" class="w-full text-left px-4 py-3 text-sm text-white/70 hover:bg-white/5 hover:text-white transition-colors border-b border-white/5 last:border-0 flex items-center justify-between">' +
            '<span>' + escapeHtml(item.name) + '</span>' +
            '<span class="text-[10px] uppercase tracking-wider text-white/20">' + (item.tty === 'IN' || item.tty === 'PIN' || item.tty === 'MIN' ? 'generic' : item.tty || '') + '</span>' +
          '</button>'
        ).join('');
        suggestionsEl.classList.remove('hidden');

        suggestionsEl.querySelectorAll('button').forEach(btn => {
          btn.addEventListener('click', () => {
            const idx = parseInt(btn.dataset.idx);
            selectSuggestion(suggestions[idx]);
          });
        });
      }

      function hideSuggestions() { suggestionsEl.classList.add('hidden'); suggestions = []; activeIdx = -1; }

      function escapeHtml(s) {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      function highlightSuggestion(idx) {
        const btns = suggestionsEl.querySelectorAll('button');
        btns.forEach((b, i) => {
          b.classList.toggle('bg-white/5', i === idx);
          b.classList.toggle('text-white', i === idx);
        });
        activeIdx = idx;
      }

      // -- RxNorm --
      async function searchDrugs(term) {
        const data = await fetchJSON(RXNORM + '/approximateTerm.json?term=' + encodeURIComponent(term) + '&maxEntries=20');
        const candidates = data?.approximateGroup?.candidate || [];

        // Dedupe by rxcui
        const seen = new Map();
        for (const c of candidates) {
          if (!seen.has(c.rxcui)) seen.set(c.rxcui, c);
        }

        const unique = [...seen.values()].slice(0, 8);
        const results = await Promise.all(unique.map(async (c) => {
          const props = await fetchJSON(RXNORM + '/rxcui/' + c.rxcui + '/properties.json');
          return {
            rxcui: c.rxcui,
            name: props?.properties?.name || 'Unknown',
            tty: props?.properties?.tty || '',
          };
        }));

        // Prefer ingredient-level names
        const ingredients = results.filter(r => ['IN', 'PIN', 'MIN'].includes(r.tty));
        return ingredients.length > 0 ? ingredients : results.slice(0, 5);
      }

      // -- Cost Plus --
      async function getCostPlusPrices(name) {
        const data = await fetchJSON(COSTPLUS + '?medication_name=' + encodeURIComponent(name));
        if (!data) return [];
        // API returns array directly or {results: [...]}
        const results = Array.isArray(data) ? data : (data.results || []);
        return results.filter(r => !r.error_message);
      }

      // -- Render Results --
      function renderResults(results, drugName) {
        hideAll();

        resultsHeader.innerHTML =
          '<div class="text-center">' +
            '<p class="text-xs uppercase tracking-[0.25em] text-white/30 mb-2">Prices for</p>' +
            '<h2 class="text-2xl sm:text-3xl font-heading font-bold italic text-white/80 capitalize">' + escapeHtml(drugName) + '</h2>' +
          '</div>';

        resultsGrid.innerHTML = results.map(r => {
          const price = r.unit_price ? formatPrice(r.unit_price) : '—';
          const costPlusUrl = r.url || ('https://costplusdrugs.com/medications/' + (r.slug || ''));
          return '' +
            '<div class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-gray-900 to-gray-800 border border-white/5 hover:border-amber-400/20 transition-all duration-300">' +
              '<div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(white 1px, transparent 1px), linear-gradient(90deg, white 1px, transparent 1px); background-size: 32px 32px;"></div>' +
              '<div class="absolute top-0 left-0 w-24 h-24 bg-amber-400/10 rounded-full blur-2xl"></div>' +
              '<div class="relative z-10 p-6">' +
                '<div class="flex items-start justify-between mb-4">' +
                  '<div>' +
                    '<p class="text-[10px] uppercase tracking-[0.25em] text-white/30 mb-1">' + escapeHtml(r.form || 'Medication') + '</p>' +
                    '<p class="text-sm font-medium text-white/70">' + escapeHtml(r.strength || '') + '</p>' +
                  '</div>' +
                  '<span class="inline-flex px-2 py-0.5 rounded bg-amber-400/10 border border-amber-400/20 text-[9px] uppercase tracking-widest text-amber-400">Cost Plus</span>' +
                '</div>' +
                '<div class="mb-5">' +
                  '<p class="text-[10px] uppercase tracking-[0.25em] text-white/30 mb-1">Price per unit</p>' +
                  '<p class="text-3xl font-bold text-amber-400">' + price + '</p>' +
                '</div>' +
                '<a href="' + costPlusUrl + '" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-xs font-medium text-amber-400/70 hover:text-amber-400 transition-colors">' +
                  'View on Cost Plus Drugs &rarr;' +
                '</a>' +
              '</div>' +
            '</div>';
        }).join('');

        resultsLinks.innerHTML =
          '<p class="text-xs text-white/25 mb-4">Compare on other platforms</p>' +
          '<div class="flex flex-wrap justify-center gap-3">' +
            '<a href="https://www.goodrx.com/search?search=' + encodeURIComponent(drugName) + '" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-xs font-medium text-white/50 hover:text-white hover:border-white/20 transition-all">GoodRx &rarr;</a>' +
            '<a href="https://www.trumprx.gov" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-xs font-medium text-white/50 hover:text-white hover:border-white/20 transition-all">TrumpRx.gov &rarr;</a>' +
          '</div>';

        resultsEl.classList.remove('hidden');
      }

      // -- Select Suggestion --
      async function selectSuggestion(s) {
        searchInput.value = s.name;
        hideSuggestions();
        showLoading();

        try {
          let results = await getCostPlusPrices(s.name);

          // If no results, try just the first word (base ingredient)
          if (results.length === 0) {
            const base = s.name.split(' ')[0];
            if (base !== s.name) {
              results = await getCostPlusPrices(base);
            }
          }

          if (results.length > 0) {
            renderResults(results, s.name);
          } else {
            showNoResults(s.name);
          }
        } catch (e) {
          showError();
        }
      }

      // -- Event Handlers --
      const handleInput = debounce(async (e) => {
        const term = e.target.value.trim();
        if (term.length < 2) { hideSuggestions(); return; }

        const items = await searchDrugs(term);
        showSuggestions(items);
      }, 350);

      searchInput.addEventListener('input', handleInput);

      searchInput.addEventListener('keydown', (e) => {
        const btns = suggestionsEl.querySelectorAll('button');
        if (!btns.length) return;

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          const next = activeIdx < btns.length - 1 ? activeIdx + 1 : 0;
          highlightSuggestion(next);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          const prev = activeIdx > 0 ? activeIdx - 1 : btns.length - 1;
          highlightSuggestion(prev);
        } else if (e.key === 'Enter') {
          e.preventDefault();
          if (activeIdx >= 0 && suggestions[activeIdx]) {
            selectSuggestion(suggestions[activeIdx]);
          }
        } else if (e.key === 'Escape') {
          hideSuggestions();
        }
      });

      document.addEventListener('click', (e) => {
        if (!e.target.closest('#rx-search-container')) hideSuggestions();
      });
    }

    // Support Astro View Transitions
    document.addEventListener('astro:page-load', init);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  </script>
</Layout>
